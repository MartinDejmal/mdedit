  "identifier": "default",
  "description": "Default capability granted to the main window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "allow-open-file-dialog",
    "allow-read-text-file",
    "allow-save-text-file",
    "allow-save-file-dialog",
    "allow-save-html-file-dialog",
    "allow-save-pdf-file-dialog",
    "allow-get-file-metadata",
    "allow-get-launch-args"
  ]
}
